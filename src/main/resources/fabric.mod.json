{
	"schemaVersion": 1,
	"id": "cropic",
	"version": "${version}",
	"name": "Cropic",
	"description": "Cropic aims to make the farming and agricultural side of Minecraft better and maybe more realistic. ",
	"authors": [
		"Tom Patton-Low"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "MIT",
	"icon": "assets/cropic/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"tompl.cropic.Cropic"
		],
		"fabric-datagen": [
			"tompl.cropic.CropicDataGenerator"
		],
		"client": [
			"tompl.cropic.CropicClient"
		]
	},
	"mixins": [
		"cropic.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.18.6",
		"minecraft": "~1.21",
		"java": ">=21",
		"fabric-api": "*"
	}
}